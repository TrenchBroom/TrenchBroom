execute_process(
  COMMAND @TB_QMAKE_PATH@ -query QT_INSTALL_LIBS
  OUTPUT_VARIABLE QT_LIBS_DIR
  OUTPUT_STRIP_TRAILING_WHITESPACE
  COMMAND_ERROR_IS_FATAL ANY
)

execute_process(
  COMMAND @TB_QMAKE_PATH@ -query QT_INSTALL_PLUGINS
  OUTPUT_VARIABLE QT_PLUGINS_DIR
  OUTPUT_STRIP_TRAILING_WHITESPACE
  COMMAND_ERROR_IS_FATAL ANY
)

# The GTK platform theme must use the host's GTK stack to match its desktop
# theme. Bundling these libraries would make the AppImage use the versions from
# the build container instead.
execute_process(
  COMMAND
    @CMAKE_COMMAND@ -E env
      LD_LIBRARY_PATH=${QT_LIBS_DIR}:$ENV{LD_LIBRARY_PATH}
      ldd "${QT_PLUGINS_DIR}/platformthemes/libqgtk3.so"
  OUTPUT_VARIABLE QGTK3_DEPENDENCIES
  COMMAND_ERROR_IS_FATAL ANY
)
string(
  REGEX MATCH
  "libgtk-3\\.so\\.0 => ([^ \n]+)"
  QGTK3_GTK_LIBRARY_MATCH
  "${QGTK3_DEPENDENCIES}"
)
set(GTK3_LIBRARY "${CMAKE_MATCH_1}")
if(NOT GTK3_LIBRARY)
  message(FATAL_ERROR "Could not resolve libgtk-3.so.0 used by Qt's GTK platform theme")
endif()

file(
  GET_RUNTIME_DEPENDENCIES
  LIBRARIES "${GTK3_LIBRARY}"
  RESOLVED_DEPENDENCIES_VAR GTK3_DEPENDENCIES
  UNRESOLVED_DEPENDENCIES_VAR GTK3_UNRESOLVED_DEPENDENCIES
)
if(GTK3_UNRESOLVED_DEPENDENCIES)
  message(FATAL_ERROR "Could not resolve GTK 3 dependencies: ${GTK3_UNRESOLVED_DEPENDENCIES}")
endif()

set(GTK3_LIBRARY_NAMES "libgtk-3.so.0" "libgthread-2.0.so.0")
foreach(GTK3_DEPENDENCY IN LISTS GTK3_DEPENDENCIES)
  get_filename_component(GTK3_DEPENDENCY_NAME "${GTK3_DEPENDENCY}" NAME)
  list(APPEND GTK3_LIBRARY_NAMES "${GTK3_DEPENDENCY_NAME}")
endforeach()
list(REMOVE_DUPLICATES GTK3_LIBRARY_NAMES)
list(FILTER GTK3_LIBRARY_NAMES EXCLUDE REGEX "^(libatomic|libgcc_s|libstdc\\+\\+)\\.so")
list(JOIN GTK3_LIBRARY_NAMES ";" TB_LINUXDEPLOY_EXCLUDED_LIBRARIES)

# Build the AppImage: deploy the executable, Qt plugins, and shared libraries,
# then package everything into an AppImage in one step.
# LD_LIBRARY_PATH is set so linuxdeploy can resolve Qt shared libraries.
# EXTRA_PLATFORM_PLUGINS bundles the Wayland platform plugins alongside the
# default xcb plugin so the app can run on both X11 and Wayland.
# EXTRA_QT_MODULES=waylandcompositor triggers linuxdeploy-plugin-qt's built-in
# WaylandcompositorPluginsDeployer, which copies the wayland-shell-integration,
# wayland-decoration-client and wayland-graphics-integration-client plugin
# directories needed for Wayland client support.
# DEPLOY_PLATFORM_THEMES bundles the GTK 3 and xdg-desktop-portal themes. The
# AppRun hook selects GTK 3 on GTK-based desktops and xdg-desktop-portal
# elsewhere, while allowing users to override QT_QPA_PLATFORMTHEME.

# Because our install() rules use COMPONENT TrenchBroom, CPack's staging
# install for the External generator places everything under
# ${CPACK_TEMPORARY_DIRECTORY}/TrenchBroom/usr/... instead of merging it
# directly into ${CPACK_TEMPORARY_DIRECTORY}/usr/..., which is where
# linuxdeploy (and the rest of this script) expect to find it. Flatten it.
if(EXISTS "${CPACK_TEMPORARY_DIRECTORY}/TrenchBroom/usr")
  file(COPY "${CPACK_TEMPORARY_DIRECTORY}/TrenchBroom/usr" DESTINATION "${CPACK_TEMPORARY_DIRECTORY}")
endif()

file(
  COPY "@TB_RESOURCE_DIR@/linux/trenchbroom-platform-theme.sh"
  DESTINATION "${CPACK_TEMPORARY_DIRECTORY}/apprun-hooks"
  FILE_PERMISSIONS
    OWNER_READ OWNER_WRITE OWNER_EXECUTE
    GROUP_READ GROUP_EXECUTE
    WORLD_READ WORLD_EXECUTE
)

execute_process(
  COMMAND
    @CMAKE_COMMAND@ -E env
      QMAKE=@TB_QMAKE_PATH@
      OUTPUT=TrenchBroom.AppImage
      LD_LIBRARY_PATH=${QT_LIBS_DIR}:$ENV{LD_LIBRARY_PATH}
      EXTRA_PLATFORM_PLUGINS=libqwayland.so
      EXTRA_QT_MODULES=waylandcompositor
      DEPLOY_PLATFORM_THEMES=1
      "LINUXDEPLOY_EXCLUDED_LIBRARIES=${TB_LINUXDEPLOY_EXCLUDED_LIBRARIES}"
    @TB_LINUXDEPLOY_PATH@
    --appdir=${CPACK_TEMPORARY_DIRECTORY}
    --desktop-file=@TB_RESOURCE_DIR@/linux/trenchbroom.desktop
    --icon-file=@TB_RESOURCE_DIR@/graphics/images/AppIcon.png
    --icon-filename=trenchbroom
    --plugin qt
    --output=appimage
  COMMAND_ERROR_IS_FATAL ANY
)

# Wrap the AppImage in a zip archive for distribution.
execute_process(
  COMMAND
    @CMAKE_COMMAND@ -E tar cv @CPACK_PACKAGE_FILE_NAME@.@CPACK_PACKAGE_FILE_EXT@ --format=zip TrenchBroom.AppImage
  COMMAND_ERROR_IS_FATAL ANY
)
