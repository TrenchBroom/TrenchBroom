<?xml version="1.0" encoding="utf-8"?>
<!--
  SignPath artifact configuration for TrenchBroom's Windows release ZIP
  (produced by CPack, see app/TrenchBroom/CMakeLists.txt).

  This file is uploaded to the SignPath project's "Artifact Configurations"
  section (Project > Artifact Configurations > Add > Custom XML) - it is not
  read by GitHub Actions directly. Keeping a copy here just for version
  control / review.

  The zip has no top-level directory (CPACK_INCLUDE_TOPLEVEL_DIRECTORY=FALSE),
  so TrenchBroom.exe and all bundled Qt/runtime DLLs sit directly under the
  archive root or in known subfolders (platforms/, styles/, tls/). The exact
  set of DLLs varies with the Qt/vcpkg versions, so DLLs are matched
  recursively with a wildcard rather than listed by name.
-->
<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">
  <zip-file>
    <pe-file path="TrenchBroom.exe">
      <authenticode-sign/>
    </pe-file>
    <pe-file-set>
      <include path="**/*.dll" min-matches="0" max-matches="unbounded"/>
      <for-each>
        <authenticode-sign/>
      </for-each>
    </pe-file-set>
  </zip-file>
</artifact-configuration>
